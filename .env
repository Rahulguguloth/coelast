# PhishSentinel Environment Configuration

# --- Telegram Alerts ---
# To get these, create a bot via @BotFather and use @userinfobot for chat ID
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Redis Configuration ---
# Used for OTP Velocity detection and rate limiting
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- OCR Configuration ---
# Path to Tesseract executable (Required for Screenshot Analysis)
# Example: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- VirusTotal API (Optional) ---
# For enhanced URL reputation checks
VT_API_KEY=your_virustotal_api_key_here

# --- App Settings ---
DEBUG=True
PORT=8501